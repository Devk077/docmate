# ============================================================
#  DoqToq — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ============================================================

# ── AI Model API Keys ────────────────────────────────────────────
# Google Gemini  → https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# Mistral        → https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Ollama runs locally — no key needed.
# Start with: ollama serve  (then: ollama pull mistral)

# ── PostgreSQL ───────────────────────────────────────────────────
# Required for room / document / session storage.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:secret@localhost:5432/doqtoq

# ── Qdrant (Vector Database) ─────────────────────────────────────
# Run locally with Docker (recommended):
#   docker compose up -d qdrant
#
# Mode: "server" uses QDRANT_URL; "local" uses QDRANT_PATH
QDRANT_MODE=server
QDRANT_URL=http://localhost:6333
QDRANT_PATH=./data/vectorstore/qdrant
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=Cosine

# ── Frontend / CORS ───────────────────────────────────────────────
# Origin that the React app is served from.
# Dev default: http://localhost:5173
# Set to your production domain when deploying.
FRONTEND_URL=http://localhost:5173

# ── DoqToq Behaviour Tuning ──────────────────────────────────────
# Minimum similarity score (0‑1) for a document to join the discussion
GROUP_SIMILARITY_THRESHOLD=0.65

# Messages before triggering per-document context compaction
GROUP_DOC_COMPACTION_N=10

# If a response is this similar (or more) to the last one, the doc is marked "spent"
GROUP_DIMINISHING_RETURNS_SIM=0.92

# Maximum documents allowed in a single Discussion Room
GROUP_MAX_ROOM_DOCS=10
